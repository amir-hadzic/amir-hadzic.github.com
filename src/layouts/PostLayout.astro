---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  date: Date;
}

const { title, date } = Astro.props;

const formatted = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} — Amir Hadžić`} description={title}>
  <article>
    <header class="mb-10">
      <h1 class="text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
        {title}
      </h1>
      <time
        datetime={date.toISOString()}
        class="mt-3 block text-sm text-text-muted"
      >
        {formatted}
      </time>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>

  <div class="mt-16">
    <a
      href="/"
      class="text-sm text-text-muted no-underline hover:text-text transition-colors"
    >
      &larr; Back to all posts
    </a>
  </div>
</BaseLayout>
