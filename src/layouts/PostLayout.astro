---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  date: Date;
  outdated?: boolean;
}

const { title, date, outdated } = Astro.props;

const formatted = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} — Amir Hadžić`} description={title}>
  <article>
    <header class="mb-10">
      <h1 class="text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
        {title}
      </h1>
      <time
        datetime={date.toISOString()}
        class="mt-3 block text-sm text-text-muted"
      >
        {formatted}
      </time>
    </header>
    {outdated && (
      <div class="mb-8 rounded border border-border bg-surface px-5 py-4 text-sm text-text-secondary font-sans">
        <strong class="text-text">This post is outdated.</strong> It was written in {date.getFullYear()} and may contain broken links or reference technologies that no longer exist. It is kept here only for historical reasons.
      </div>
    )}
    <div class="prose">
      <slot />
    </div>
  </article>

  <div class="mt-16">
    <a
      href="/"
      class="text-sm text-text-muted no-underline hover:text-text transition-colors"
    >
      &larr; Back to all posts
    </a>
  </div>
</BaseLayout>
